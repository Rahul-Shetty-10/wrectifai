# Toggle app environment:
NEXT_PUBLIC_APP_ENV=local
# NEXT_PUBLIC_APP_ENV=production

# API base URL (toggle one line based on environment):
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
# NEXT_PUBLIC_API_BASE_URL=https://your-api-domain.com/api

# If web and API are same-origin in production, comment out NEXT_PUBLIC_API_BASE_URL
# and set NEXT_PUBLIC_SITE_URL + API_PROXY_TARGET:
# NEXT_PUBLIC_SITE_URL=https://your-web-domain.com
# API_PROXY_TARGET=https://your-api-domain.com

# Multi-tenant UI content key:
NEXT_PUBLIC_TENANT_ID=default
