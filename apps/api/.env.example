# Toggle app environment:
APP_ENV=local
# APP_ENV=production

# Server:
HOST=localhost
PORT=3000

# CORS origins (toggle one line based on environment):
WEB_ORIGINS=http://localhost:4200
# WEB_ORIGINS=https://your-web-domain.com,https://your-web-preview.vercel.app

# Database:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wrectifai
# DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>

# Cookie behavior:
COOKIE_SAME_SITE=lax
# COOKIE_SAME_SITE=none
# COOKIE_SECURE=true
# COOKIE_DOMAIN=.yourdomain.com

# OTP behavior:
# Local/dev default: fixed OTP for quick testing.
AUTH_OTP_FIXED_CODE=123456
AUTH_OTP_DEBUG_ECHO=true

# Production recommended:
# 1) remove fixed OTP
# 2) disable OTP debug echo
# AUTH_OTP_FIXED_CODE=
# AUTH_OTP_DEBUG_ECHO=false
AUTH_OTP_TTL_SECONDS=300

# Social auth:
# Local/dev can keep this on if you are testing mocked social identity.
AUTH_SOCIAL_ENABLED=true
AUTH_SOCIAL_ALLOW_DEV_SUBJECT_FALLBACK=true

# Production recommended:
# AUTH_SOCIAL_ENABLED=false
# AUTH_SOCIAL_ALLOW_DEV_SUBJECT_FALLBACK=false

# AI diagnosis:
# GEMINI_API_KEY=your_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.0-flash
GEMINI_RETRIES=2
